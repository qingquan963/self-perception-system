# 生产环境配置
ENVIRONMENT=production
VERSION=V1.8_optimized
PYTHONPATH=[REDACTED]

# 数据库配置
CHROMA_DB_PATH=[REDACTED]
MEMORY_DATA_PATH=[REDACTED]

# 日志配置
LOG_LEVEL=INFO
LOG_PATH=[REDACTED]

# 性能监控
MONITORING_ENABLED=true
ALERT_THRESHOLD_ACCURACY=0.95
ALERT_THRESHOLD_ERROR=10.0
ALERT_THRESHOLD_RESPONSE_TIME=2.0

# 回滚配置
ROLLBACK_ENABLED=true
BACKUP_VERSION_PATH=[REDACTED]
