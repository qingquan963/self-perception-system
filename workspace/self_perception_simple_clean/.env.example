# =============================================
# 自我感知 + 做梦模式 整合系统
# 环境变量配置示例
# =============================================
# 复制此文件为 .env，填入真实值
# cp .env.example .env

# ── API Keys ──────────────────────────────────────────────────────
MINIMAX_API_KEY=your_minimax_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here

# ── 服务端口 ──────────────────────────────────────────────────────
VECTOR_SERVICE_PORT=8007
API_SERVICE_PORT=8011
DREAM_SERVICE_PORT=8001

# ── Token 监控 ─────────────────────────────────────────────────────
TOKEN_MONITOR_ENABLED=true
TOKEN_WARNING_THRESHOLD=80
TOKEN_CLEANUP_THRESHOLD=85
TOKEN_CRITICAL_THRESHOLD=90
MAX_CONTEXT_TOKENS=128000

# ── Compaction Writer ──────────────────────────────────────────────
# Session 摘要文件目录（Docker 中映射到宿主机的 sessions）
SESSION_JSONL_DIR={{SESSION_JSONL_DIR:-/sessions}

# ── 系统 ───────────────────────────────────────────────────────────
SELF_PERCEPTION_SYSTEM=true
